{
  "manifest_version": 3,
  "name": "Trailroam for Strava",
  "description": "Import Strava activities locally and view routes in a full-page extension app.",
  "version": "0.0.1",
  "action": {
    "default_title": "Trailroam for Strava",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.strava.com/*",
    "https://strava.com/*",
    "https://tiles.openfreemap.org/*"
  ]
}
